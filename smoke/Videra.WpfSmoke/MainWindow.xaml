<Window x:Class="Videra.WpfSmoke.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Videra.WpfSmoke"
        Title="Videra WPF Smoke"
        Width="960"
        Height="640"
        WindowStartupLocation="CenterScreen"
        Background="#020617">
  <Grid Margin="12">
    <Grid.RowDefinitions>
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <local:ViewerHwndHost x:Name="ViewerHost" Grid.Row="0" />
    <TextBlock x:Name="StatusText"
               Grid.Row="1"
               Margin="0,12,0,0"
               Foreground="#CBD5E1"
               FontSize="13"
               TextWrapping="NoWrap"
               TextTrimming="CharacterEllipsis" />
  </Grid>
</Window>
