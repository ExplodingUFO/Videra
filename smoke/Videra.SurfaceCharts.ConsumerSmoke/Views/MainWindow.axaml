<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:charts="using:Videra.SurfaceCharts.Avalonia.Controls"
        x:Class="Videra.SurfaceCharts.ConsumerSmoke.Views.MainWindow"
        Width="1100"
        Height="700"
        Title="Videra SurfaceCharts Consumer Smoke"
        Background="#08111F">
  <Grid RowDefinitions="*,Auto">
    <Border Margin="18,18,18,10"
            Background="#0F172A"
            BorderBrush="#1F2B44"
            BorderThickness="1"
            CornerRadius="18"
            ClipToBounds="True">
      <charts:SurfaceChartView x:Name="ChartView" />
    </Border>
    <TextBlock Grid.Row="1"
               x:Name="StatusText"
               Margin="18,0,18,18"
               Foreground="#CBD5E1"
               TextWrapping="Wrap" />
  </Grid>
</Window>
