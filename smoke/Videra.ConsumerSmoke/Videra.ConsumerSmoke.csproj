<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AvaloniaUseCompiledBindingsByDefault>true</AvaloniaUseCompiledBindingsByDefault>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <NoWarn>CS1591</NoWarn>
    <VideraConsumerPackageVersion Condition="'$(VideraConsumerPackageVersion)' == ''">$(Version)</VideraConsumerPackageVersion>
    <VideraConsumerSmokeModelFormat Condition="'$(VideraConsumerSmokeModelFormat)' == ''">Obj</VideraConsumerSmokeModelFormat>
  </PropertyGroup>

  <PropertyGroup Condition="'$(VideraConsumerSmokeModelFormat)' == 'Obj'">
    <DefineConstants>$(DefineConstants);VIDERA_CONSUMER_SMOKE_OBJ</DefineConstants>
  </PropertyGroup>

  <PropertyGroup Condition="'$(VideraConsumerSmokeModelFormat)' == 'Gltf'">
    <DefineConstants>$(DefineConstants);VIDERA_CONSUMER_SMOKE_GLTF</DefineConstants>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Avalonia" Version="11.3.9" />
    <PackageReference Include="Avalonia.Desktop" Version="11.3.9" />
    <PackageReference Include="Avalonia.Themes.Fluent" Version="11.3.9" />
    <PackageReference Include="Avalonia.Fonts.Inter" Version="11.3.9" />
    <PackageReference Include="Avalonia.Diagnostics" Version="11.3.9">
      <IncludeAssets Condition="'$(Configuration)' != 'Debug'">None</IncludeAssets>
      <PrivateAssets Condition="'$(Configuration)' != 'Debug'">All</PrivateAssets>
    </PackageReference>
    <PackageReference Include="Videra.Avalonia" Version="$(VideraConsumerPackageVersion)" />
  </ItemGroup>

  <ItemGroup Condition="'$(VideraConsumerSmokeModelFormat)' == 'Obj'">
    <PackageReference Include="Videra.Import.Obj" Version="$(VideraConsumerPackageVersion)" />
  </ItemGroup>

  <ItemGroup Condition="'$(VideraConsumerSmokeModelFormat)' == 'Gltf'">
    <PackageReference Include="Videra.Import.Gltf" Version="$(VideraConsumerPackageVersion)" />
  </ItemGroup>

  <ItemGroup Condition="$([MSBuild]::IsOSPlatform('Windows'))">
    <PackageReference Include="Videra.Platform.Windows" Version="$(VideraConsumerPackageVersion)" />
  </ItemGroup>

  <ItemGroup Condition="$([MSBuild]::IsOSPlatform('Linux'))">
    <PackageReference Include="Videra.Platform.Linux" Version="$(VideraConsumerPackageVersion)" />
  </ItemGroup>

  <ItemGroup Condition="$([MSBuild]::IsOSPlatform('OSX'))">
    <PackageReference Include="Videra.Platform.macOS" Version="$(VideraConsumerPackageVersion)" />
  </ItemGroup>

  <ItemGroup>
    <None Include="Assets\reference-cube.obj" CopyToOutputDirectory="PreserveNewest" />
    <None Include="Assets\reference-triangle.gltf" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>
</Project>
