<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:charts="using:Videra.SurfaceCharts.Avalonia.Controls"
        x:Class="Videra.SurfaceCharts.Demo.Views.MainWindow"
        Title="Videra Surface Charts Demo"
        Width="1440"
        Height="900"
        MinWidth="1180"
        MinHeight="760"
        Background="#08111F">
  <Grid ColumnDefinitions="2.2*,1*" RowDefinitions="Auto,*">
    <Border Grid.ColumnSpan="2"
            Background="#101A2D"
            BorderBrush="#1F2B44"
            BorderThickness="0,0,0,1"
            Padding="24,18">
      <StackPanel Spacing="6">
        <TextBlock FontSize="26"
                   FontWeight="SemiBold"
                   Foreground="#E2E8F0"
                   Text="Surface Charts Demo" />
        <TextBlock Foreground="#CBD5E1"
                   TextWrapping="Wrap"
                   Text="Start with the in-memory first-chart path, then opt into cache-backed streaming and the secondary chart diagnostics once that happy path renders. The demo stays in its own sample app and only depends on the surface-chart module family." />
      </StackPanel>
    </Border>

    <Border Grid.Row="1"
            Margin="24,24,12,24"
            Background="#0F172A"
            BorderBrush="#1F2B44"
            BorderThickness="1"
            CornerRadius="20"
            ClipToBounds="True">
      <charts:SurfaceChartView x:Name="ChartView" />
    </Border>

    <ScrollViewer Grid.Row="1"
                  Grid.Column="1"
                  Margin="12,24,24,24"
                  VerticalScrollBarVisibility="Auto">
      <StackPanel Spacing="14">
        <Border Padding="18"
                Background="#111A2B"
                BorderBrush="#1F2B44"
                BorderThickness="1"
                CornerRadius="18">
          <StackPanel Spacing="10">
            <TextBlock FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="#E2E8F0"
                       Text="First-chart source" />
            <ComboBox x:Name="SourceSelector">
              <ComboBoxItem Content="Start here: In-memory first chart" />
              <ComboBoxItem Content="Explore next: Cache-backed streaming" />
            </ComboBox>
            <TextBlock Foreground="#CBD5E1"
                       TextWrapping="Wrap"
                       Text="Start here with the in-memory source-first first chart. Switch to cache-backed streaming only after the first chart renders and you want the broader exploration path." />
          </StackPanel>
        </Border>

        <Border Padding="18"
                Background="#111A2B"
                BorderBrush="#1F2B44"
                BorderThickness="1"
                CornerRadius="18">
          <StackPanel Spacing="10">
            <TextBlock FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="#E2E8F0"
                       Text="View-state contract" />
            <StackPanel Orientation="Horizontal"
                        Spacing="8">
              <Button x:Name="FitToDataButton"
                      Content="Fit to data" />
              <Button x:Name="ResetCameraButton"
                      Content="Reset camera" />
            </StackPanel>
            <TextBlock x:Name="ViewStateText"
                       Foreground="#CBD5E1"
                       TextWrapping="Wrap" />
            <TextBlock Foreground="#CBD5E1"
                       TextWrapping="Wrap"
                       Text="`ViewState` is the primary chart-view contract. `Fit to data` and `Reset camera` stay as deterministic host commands on top of the same built-in interaction runtime." />
          </StackPanel>
        </Border>

        <Border Padding="18"
                Background="#111A2B"
                BorderBrush="#1F2B44"
                BorderThickness="1"
                CornerRadius="18">
          <StackPanel Spacing="8">
            <TextBlock FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="#E2E8F0"
                       Text="Start here status" />
            <TextBlock x:Name="StatusText"
                       Foreground="#CBD5E1"
                       TextWrapping="Wrap" />
          </StackPanel>
        </Border>

        <Border Padding="18"
                Background="#111A2B"
                BorderBrush="#1F2B44"
                BorderThickness="1"
                CornerRadius="18">
          <StackPanel Spacing="8">
            <TextBlock FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="#E2E8F0"
                       Text="Built-in interaction" />
            <TextBlock Foreground="#CBD5E1"
                       TextWrapping="Wrap"
                       Text="Left drag orbit. Right drag pan. Wheel dolly. Ctrl + Left drag focus zoom." />
          </StackPanel>
        </Border>

        <Border Padding="18"
                Background="#111A2B"
                BorderBrush="#1F2B44"
                BorderThickness="1"
                CornerRadius="18">
          <StackPanel Spacing="8">
            <TextBlock FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="#E2E8F0"
                       Text="Interaction quality" />
            <TextBlock x:Name="InteractionQualityText"
                       Foreground="#CBD5E1"
                       TextWrapping="Wrap" />
          </StackPanel>
        </Border>

        <Border Padding="18"
                Background="#111A2B"
                BorderBrush="#1F2B44"
                BorderThickness="1"
                CornerRadius="18">
          <StackPanel Spacing="8">
            <TextBlock FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="#E2E8F0"
                       Text="Explore next: Rendering path" />
            <TextBlock x:Name="RenderingPathText"
                       Foreground="#CBD5E1"
                       TextWrapping="Wrap" />
          </StackPanel>
        </Border>

        <Border Padding="18"
                Background="#111A2B"
                BorderBrush="#1F2B44"
                BorderThickness="1"
                CornerRadius="18">
          <StackPanel Spacing="8">
            <TextBlock FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="#E2E8F0"
                       Text="Explore next: Probe workflow" />
            <TextBlock Foreground="#CBD5E1"
                       TextWrapping="Wrap"
                       Text="Hover readout follows the current tile truth. Use Shift + LeftClick to pin a probe and keep it visible while detail tiles continue refining." />
          </StackPanel>
        </Border>

        <Border Padding="18"
                Background="#111A2B"
                BorderBrush="#1F2B44"
                BorderThickness="1"
                CornerRadius="18">
          <StackPanel Spacing="8">
            <TextBlock FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="#E2E8F0"
                       Text="Explore next: Axes and legend" />
            <TextBlock Foreground="#CBD5E1"
                       TextWrapping="Wrap"
                       Text="Axes, labels, and legend overlays ship with the chart surface today, alongside built-in orbit, pan, dolly, and focus interaction." />
          </StackPanel>
        </Border>

        <Border Padding="18"
                Background="#111A2B"
                BorderBrush="#1F2B44"
                BorderThickness="1"
                CornerRadius="18">
          <StackPanel Spacing="8">
            <TextBlock FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="#E2E8F0"
                       Text="Explore next: Overlay options" />
            <TextBlock x:Name="OverlayOptionsText"
                       Foreground="#CBD5E1"
                       TextWrapping="Wrap" />
          </StackPanel>
        </Border>

        <Border Padding="18"
                Background="#111A2B"
                BorderBrush="#1F2B44"
                BorderThickness="1"
                CornerRadius="18">
          <StackPanel Spacing="8">
            <TextBlock FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="#E2E8F0"
                       Text="Advanced: cache asset" />
            <TextBlock x:Name="CachePathText"
                       Foreground="#CBD5E1"
                       TextWrapping="Wrap" />
          </StackPanel>
        </Border>

        <Border Padding="18"
                Background="#111A2B"
                BorderBrush="#1F2B44"
                BorderThickness="1"
                CornerRadius="18">
          <StackPanel Spacing="8">
            <TextBlock FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="#E2E8F0"
                       Text="Dataset summary" />
            <TextBlock x:Name="DatasetText"
                       Foreground="#CBD5E1"
                       TextWrapping="Wrap" />
          </StackPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Window>
