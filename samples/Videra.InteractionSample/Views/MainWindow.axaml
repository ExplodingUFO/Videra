<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:videra="using:Videra.Avalonia.Controls"
        x:Class="Videra.InteractionSample.Views.MainWindow"
        Title="Videra Interaction Sample"
        Width="1500"
        Height="920"
        MinWidth="1180"
        MinHeight="760"
        Background="#F7F3EA">
  <Grid ColumnDefinitions="2.3*,1.15*" RowDefinitions="Auto,*">
    <Border Grid.ColumnSpan="2"
            Background="#F0E4D3"
            BorderBrush="#A46C3B"
            BorderThickness="0,0,0,1"
            Padding="26,18">
      <StackPanel Spacing="8">
        <TextBlock FontSize="26"
                   FontWeight="SemiBold"
                   Foreground="#3D2716"
                   Text="Focused public interaction sample" />
        <TextBlock Foreground="#6B4B2D"
                   TextWrapping="Wrap"
                   Text="The host owns SelectionState, Annotations, and annotation state, switches between Navigate, Select, Annotate, and Measure, and exercises clipping, view-state capture, and snapshot export through the public inspection workflow." />
      </StackPanel>
    </Border>

    <Border Grid.Row="1"
            Margin="24,24,12,24"
            Background="#FBF7F1"
            BorderBrush="#D8B48D"
            BorderThickness="1"
            CornerRadius="22"
            ClipToBounds="True">
      <videra:VideraView x:Name="View3D"
                         PreferredBackend="Auto"
                         BackgroundColor="#FFF8EC"
                         GridColor="#C59D6B"
                         IsGridVisible="True" />
    </Border>

    <ScrollViewer Grid.Row="1"
                  Grid.Column="1"
                  Margin="12,24,24,24"
                  VerticalScrollBarVisibility="Auto">
      <StackPanel Spacing="14">
        <Border Padding="18"
                Background="#FFF8EE"
                BorderBrush="#D8B48D"
                BorderThickness="1"
                CornerRadius="18">
          <StackPanel Spacing="10">
            <TextBlock FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="#3D2716"
                       Text="Interaction contract" />
            <TextBlock Foreground="#6B4B2D"
                       TextWrapping="Wrap"
                       Text="Selection is object-level. Annotations can target object anchors through VideraNodeAnnotation or world-point anchors through VideraWorldPointAnnotation. Overlay responsibilities are split between 3D highlight/render state and 2D label/feedback rendering." />
            <TextBlock x:Name="ContractStatusText"
                       Foreground="#6B4B2D"
                       TextWrapping="Wrap" />
          </StackPanel>
        </Border>

        <Border Padding="18"
                Background="#FFF8EE"
                BorderBrush="#D8B48D"
                BorderThickness="1"
                CornerRadius="18">
          <StackPanel Spacing="10">
            <TextBlock FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="#3D2716"
                       Text="Mode switcher" />
            <StackPanel Orientation="Horizontal"
                        Spacing="10">
              <Button x:Name="NavigateModeButton"
                      Click="OnNavigateModeClicked"
                      Content="Navigate" />
              <Button x:Name="SelectModeButton"
                      Click="OnSelectModeClicked"
                      Content="Select" />
              <Button x:Name="AnnotateModeButton"
                      Click="OnAnnotateModeClicked"
                      Content="Annotate" />
              <Button x:Name="MeasureModeButton"
                      Click="OnMeasureModeClicked"
                      Content="Measure" />
              <Button x:Name="MeasurementSnapModeButton"
                      Click="OnMeasurementSnapModeClicked"
                      Content="Snap: Free" />
            </StackPanel>
            <TextBlock Foreground="#6B4B2D"
                       TextWrapping="Wrap"
                       Text="Navigate keeps camera motion on the control. Select emits SelectionRequested without mutating host state. Annotate emits AnnotationRequested for either an object hit or a world-point click. Measure creates lightweight viewer-first distance probes directly on the public inspection surface, and the snap button cycles Free / Vertex / EdgeMidpoint / Face / AxisLocked without introducing editor UI." />
          </StackPanel>
        </Border>

        <Border Padding="18"
                Background="#FFF8EE"
                BorderBrush="#D8B48D"
                BorderThickness="1"
                CornerRadius="18">
          <StackPanel Spacing="10">
            <TextBlock FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="#3D2716"
                       Text="Host actions" />
            <StackPanel Orientation="Horizontal"
                        Spacing="10">
              <Button Click="OnClearSelectionClicked"
                      Content="Clear Selection" />
              <Button Click="OnClearAnnotationsClicked"
                      Content="Clear Annotations" />
              <Button Click="OnClearMeasurementsClicked"
                      Content="Clear Measurements" />
              <Button Click="OnReseedAnnotationsClicked"
                      Content="Reseed Notes" />
            </StackPanel>
            <TextBlock Foreground="#6B4B2D"
                       TextWrapping="Wrap"
                       Text="These buttons update host-owned selection/annotation state and clear the public inspection measurements carried by View3D.Measurements." />
          </StackPanel>
        </Border>

        <Border Padding="18"
                Background="#FFF8EE"
                BorderBrush="#D8B48D"
                BorderThickness="1"
                CornerRadius="18">
          <StackPanel Spacing="10">
            <TextBlock FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="#3D2716"
                       Text="Inspection workflow" />
            <WrapPanel ItemWidth="150"
                       Orientation="Horizontal">
              <Button Click="OnToggleSectionPlaneClicked"
                      Content="Toggle Section Plane" />
              <Button Click="OnCaptureInspectionStateClicked"
                      Content="Save View State" />
              <Button Click="OnRestoreInspectionStateClicked"
                      Content="Restore View State" />
              <Button Click="OnExportSnapshotClicked"
                      Content="Export Snapshot" />
              <Button Click="OnExportInspectionBundleClicked"
                      Content="Export Bundle" />
              <Button Click="OnImportInspectionBundleClicked"
                      Content="Import Bundle" />
            </WrapPanel>
            <TextBlock Foreground="#6B4B2D"
                       TextWrapping="Wrap"
                       Text="The inspection surface stays viewer-first: clipping uses public ClippingPlanes, state persistence uses CaptureInspectionState/ApplyInspectionState, snapshot export stays on ExportSnapshotAsync, and replayable support artifacts flow through VideraInspectionBundleService." />
            <TextBlock x:Name="InspectionStatusText"
                       Foreground="#6B4B2D"
                       TextWrapping="Wrap" />
          </StackPanel>
        </Border>

        <Border Padding="18"
                Background="#FFF8EE"
                BorderBrush="#D8B48D"
                BorderThickness="1"
                CornerRadius="18">
          <StackPanel Spacing="8">
            <TextBlock FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="#3D2716"
                       Text="Scene load" />
            <TextBlock x:Name="LoadStatusText"
                       Foreground="#6B4B2D"
                       TextWrapping="Wrap" />
          </StackPanel>
        </Border>

        <Border Padding="18"
                Background="#FFF8EE"
                BorderBrush="#D8B48D"
                BorderThickness="1"
                CornerRadius="18">
          <StackPanel Spacing="8">
            <TextBlock FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="#3D2716"
                       Text="Current scene" />
            <TextBlock x:Name="SceneStatusText"
                       Foreground="#6B4B2D"
                       TextWrapping="Wrap" />
          </StackPanel>
        </Border>

        <Border Padding="18"
                Background="#FFF8EE"
                BorderBrush="#D8B48D"
                BorderThickness="1"
                CornerRadius="18">
          <StackPanel Spacing="8">
            <TextBlock FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="#3D2716"
                       Text="SelectionState" />
            <TextBlock x:Name="SelectionStatusText"
                       Foreground="#6B4B2D"
                       TextWrapping="Wrap" />
          </StackPanel>
        </Border>

        <Border Padding="18"
                Background="#FFF8EE"
                BorderBrush="#D8B48D"
                BorderThickness="1"
                CornerRadius="18">
          <StackPanel Spacing="8">
            <TextBlock FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="#3D2716"
                       Text="Annotations" />
            <TextBlock x:Name="AnnotationStatusText"
                       Foreground="#6B4B2D"
                       TextWrapping="Wrap" />
          </StackPanel>
        </Border>

        <Border Padding="18"
                Background="#FFF8EE"
                BorderBrush="#D8B48D"
                BorderThickness="1"
                CornerRadius="18">
          <StackPanel Spacing="8">
            <TextBlock FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="#3D2716"
                       Text="Measurements" />
            <TextBlock x:Name="MeasurementStatusText"
                       Foreground="#6B4B2D"
                       TextWrapping="Wrap" />
          </StackPanel>
        </Border>

        <Border Padding="18"
                Background="#FFF8EE"
                BorderBrush="#D8B48D"
                BorderThickness="1"
                CornerRadius="18">
          <StackPanel Spacing="8">
            <TextBlock FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="#3D2716"
                       Text="Last request" />
            <TextBlock x:Name="LastRequestText"
                       Foreground="#6B4B2D"
                       TextWrapping="Wrap" />
          </StackPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Window>
