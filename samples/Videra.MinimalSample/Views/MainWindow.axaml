<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:videra="using:Videra.Avalonia.Controls"
        x:Class="Videra.MinimalSample.Views.MainWindow"
        Title="Videra Minimal Sample"
        Width="1280"
        Height="800"
        MinWidth="960"
        MinHeight="640"
        Background="#020617">
  <Grid ColumnDefinitions="2.5*,1.1*" RowDefinitions="Auto,*">
    <Border Grid.ColumnSpan="2"
            Background="#0F172A"
            BorderBrush="#1E293B"
            BorderThickness="0,0,0,1"
            Padding="24,18">
      <StackPanel Spacing="8">
        <TextBlock FontSize="24"
                   FontWeight="SemiBold"
                   Foreground="#E2E8F0"
                   Text="Minimal first-scene sample" />
        <TextBlock Foreground="#CBD5E1"
                   TextWrapping="Wrap"
                   Text="This sample keeps the public alpha happy path short: configure VideraViewOptions, wait for backend readiness, call LoadModelAsync(&quot;Assets/reference-cube.obj&quot;), then use Frame All, Reset Camera, and BackendDiagnostics." />
      </StackPanel>
    </Border>

    <Border Grid.Row="1"
            Margin="24,24,12,24"
            CornerRadius="18"
            BorderBrush="#1E293B"
            BorderThickness="1"
            ClipToBounds="True">
      <videra:VideraView x:Name="View3D"
                         BackgroundColor="#0F172A"
                         GridColor="#475569"
                         IsGridVisible="True" />
    </Border>

    <ScrollViewer Grid.Row="1"
                  Grid.Column="1"
                  Margin="12,24,24,24"
                  VerticalScrollBarVisibility="Auto">
      <StackPanel Spacing="14">
        <Border Padding="18"
                Background="#0F172A"
                BorderBrush="#1E293B"
                BorderThickness="1"
                CornerRadius="18">
          <StackPanel Spacing="10">
            <TextBlock FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="#F8FAFC"
                       Text="Happy path" />
            <TextBlock Foreground="#CBD5E1"
                       Text="VideraViewOptions" />
            <TextBlock Foreground="#CBD5E1"
                       Text="LoadModelAsync(&quot;Assets/reference-cube.obj&quot;)" />
            <TextBlock Foreground="#CBD5E1"
                       Text="FrameAll()" />
            <TextBlock Foreground="#CBD5E1"
                       Text="ResetCamera()" />
            <TextBlock Foreground="#CBD5E1"
                       Text="BackendDiagnostics" />
          </StackPanel>
        </Border>

        <Border Padding="18"
                Background="#0F172A"
                BorderBrush="#1E293B"
                BorderThickness="1"
                CornerRadius="18">
          <StackPanel Spacing="8">
            <TextBlock FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="#F8FAFC"
                       Text="Scene status" />
            <TextBlock x:Name="StatusText"
                       Foreground="#CBD5E1"
                       TextWrapping="Wrap" />
          </StackPanel>
        </Border>

        <Border Padding="18"
                Background="#0F172A"
                BorderBrush="#1E293B"
                BorderThickness="1"
                CornerRadius="18">
          <StackPanel Spacing="10">
            <TextBlock FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="#F8FAFC"
                       Text="Camera" />
            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
              <Button x:Name="FrameAllButton"
                      Content="Frame All"
                      HorizontalAlignment="Stretch" />
              <Button Grid.Column="1"
                      x:Name="ResetCameraButton"
                      Content="Reset Camera"
                      HorizontalAlignment="Stretch" />
            </Grid>
            <Button x:Name="ReloadButton"
                    Content="Reload Sample Scene"
                    HorizontalAlignment="Stretch" />
          </StackPanel>
        </Border>

        <Border Padding="18"
                Background="#0F172A"
                BorderBrush="#1E293B"
                BorderThickness="1"
                CornerRadius="18">
          <StackPanel Spacing="8">
            <TextBlock FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="#F8FAFC"
                       Text="Backend diagnostics" />
            <Button x:Name="CopyDiagnosticsButton"
                    Content="Copy Diagnostics Snapshot"
                    HorizontalAlignment="Stretch" />
            <TextBlock x:Name="DiagnosticsText"
                       Foreground="#CBD5E1"
                       TextWrapping="Wrap" />
          </StackPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Window>
